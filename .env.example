DATABASE_URL=postgresql+asyncpg://adeptus:adeptus@localhost:5432/adeptus
ADEPTUS_ADMIN_USER=admin
# Generate with: python3 -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('changeme'))"
# IMPORTANT: docker compose interpolates '$' in env_file values, which would mangle
# the argon2 hash and break admin login. Escape every '$' as '$$' in this value.
# (The container receives the de-escaped single-'$' hash.) One-liner to escape:
#   ... | sed 's/\$/$$/g'
ADEPTUS_ADMIN_PASSWORD_HASH=$$argon2id$$v=19$$m=65536,t=3,p=4$$<salt>$$<hash>
SESSION_COOKIE_NAME=session_id
SESSION_TTL_DAYS=14
ENVIRONMENT=development

# DEV/TEST ONLY — a second non-admin user seeded at startup so you can test
# membership/invite flows. IGNORED when ENVIRONMENT=production. Plaintext password
# is hashed at seed time (unlike the admin, which takes a pre-computed hash).
ADEPTUS_TEST_USER_USERNAME=tester
ADEPTUS_TEST_USER_PASSWORD=changeme

# Path to the MCP server registry YAML file. In Docker Compose this is set
# directly in docker-compose.yml (overrides env_file) so you only need this
# here when running the backend outside Docker (e.g. bare-metal dev or CI).
# The default (/etc/adeptus/mcp.yaml) matches the Compose mount target.
MCP_CONFIG_PATH=/etc/adeptus/mcp.yaml
