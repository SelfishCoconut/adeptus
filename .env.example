DATABASE_URL=postgresql+asyncpg://adeptus:adeptus@localhost:5432/adeptus
ADEPTUS_ADMIN_USER=admin
# Generate with: python3 -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('changeme'))"
ADEPTUS_ADMIN_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$<salt>$<hash>
SESSION_COOKIE_NAME=session_id
SESSION_TTL_DAYS=14
ENVIRONMENT=development
