# Optional override for the backend ORIGIN. Leave empty for same-origin:
# in dev, Vite proxies /api -> http://localhost:8000 (see vite.config.ts);
# in prod the reverse proxy serves the API under the same origin.
# The /api/v1 path prefix is already part of the generated OpenAPI client
# paths, so it must NOT be included here.
VITE_API_BASE_URL=
